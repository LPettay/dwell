{
  "name": "dwell",
  "version": "0.0.1",
  "description": "An agent dwells on a website — lingers, watches, pokes, returns — and reports what it's like.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "bun": ">=1.1.0"
  },
  "bin": {
    "dwell": "./src/cli/dwell.ts"
  },
  "scripts": {
    "dwell": "bun src/cli/dwell.ts",
    "check": "bun run scripts/check.ts",
    "check:agents": "bun run scripts/check.ts --only=presence,freshness",
    "check:fs": "bun run scripts/check.ts --only=forbidden",
    "typecheck": "bun x tsc --noEmit",
    "agents:stamp": "bun run scripts/stamp.ts",
    "agents:stamp-all": "bun run scripts/stamp.ts --all",
    "agents:stale": "bun run scripts/check.ts --only=freshness --verbose",
    "prepare": "bun x lefthook install || true"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "playwright": "^1.49.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.13",
    "lefthook": "^1.7.0",
    "typescript": "^5.6.3"
  }
}
